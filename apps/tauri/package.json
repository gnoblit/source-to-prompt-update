{
  "name": "@ysp/tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Primary Tauri shell for Your Source to Prompt.",
  "scripts": {
    "doctor": "node ../../scripts/run-tauri-doctor.mjs",
    "doctor:linux": "node ../../scripts/run-tauri-doctor.mjs linux",
    "doctor:windows": "node ../../scripts/run-tauri-doctor.mjs windows",
    "deps:linux": "bash ../../scripts/install-tauri-linux-deps.sh",
    "cargo:check": "node ../../scripts/run-tauri-cargo.mjs check",
    "cargo:check:fresh": "CARGO_TARGET_DIR=/tmp/ysp-tauri-check node ../../scripts/run-tauri-cargo.mjs check",
    "cargo:run": "node ../../scripts/run-tauri-cargo.mjs run",
    "dev": "node ../../scripts/run-tauri-cli.mjs dev --config src-tauri/tauri.conf.json",
    "dev:fresh": "CARGO_TARGET_DIR=/tmp/ysp-tauri-dev node ../../scripts/run-tauri-cli.mjs dev --config src-tauri/tauri.conf.json",
    "build": "node ../../scripts/run-tauri-cli.mjs build --config src-tauri/tauri.conf.json",
    "build:fresh": "CARGO_TARGET_DIR=/tmp/ysp-tauri-build node ../../scripts/run-tauri-cli.mjs build --config src-tauri/tauri.conf.json"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
