{
  "name": "your-source-to-prompt-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "electron": "^35.1.5"
  },
  "scripts": {
    "dev": "npm run electron:dev",
    "stop": "npm run electron:stop",
    "lint": "echo \"lint not configured yet\"",
    "test": "node --test tests/core/*.test.js tests/application/*.test.js tests/integration/*.test.js",
    "build": "npm run electron:build",
    "electron:dev": "npm --workspace @ysp/electron run dev",
    "electron:stop": "node scripts/stop-electron.mjs",
    "electron:build": "echo \"Electron packaging not configured yet\""
  }
}
